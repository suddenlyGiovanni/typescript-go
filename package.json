{
    "private": true,
    "name": "typescript-go",
    "version": "0.0.0",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=20.19"
    },
    "devDependencies": {
        "@types/adm-zip": "^0.5.8",
        "@types/node": "latest",
        "@types/tmp": "^0.2.6",
        "@types/which": "^3.0.4",
        "adm-zip": "^0.5.17",
        "chokidar": "^5.0.0",
        "dprint": "^0.54.0",
