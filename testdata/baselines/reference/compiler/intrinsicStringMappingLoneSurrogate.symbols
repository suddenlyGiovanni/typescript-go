// Intrinsic string mapping types should preserve lone surrogates, matching tsc.
// A lone surrogate has no case mapping, so it passes through unchanged.
type U = Uppercase<"\uD800">;
>U : Symbol(U, Decl(intrinsicStringMappingLoneSurrogate.ts, 0, 0))
>Uppercase : Symbol(Uppercase, Decl(lib.es5.d.ts, --, --))

type L = Lowercase<"A\uD800B">;
>L : Symbol(L, Decl(intrinsicStringMappingLoneSurrogate.ts, 2, 29))
>Lowercase : Symbol(Lowercase, Decl(lib.es5.d.ts, --, --))

type C = Capitalize<"\uDC00x">;
>C : Symbol(C, Decl(intrinsicStringMappingLoneSurrogate.ts, 3, 31))
>Capitalize : Symbol(Capitalize, Decl(lib.es5.d.ts, --, --))

type Un = Uncapitalize<"\uD834X">;
