//// [tests/cases/compiler/jsdocModifiersInObjectLiteral.ts] ////

=== test.js ===
// Object literal members aren't class-like members, so JSDoc modifiers like
// @override or @readonly aren't real modifiers and must not produce grammar
// errors, regardless of checkJs (#4437).

const obj = {
>obj : { created(): void; onClose_(): void; value: number; load(): Promise<void>; }
>{  /** @override */  created() {  },  /** @private */  onClose_() {  },  /** @readonly */  get value() {    return 1;  },  /** @protected */  set value(v) {  },  /** @public */  async load() {  },} : { created(): void; onClose_(): void; value: number; load(): Promise<void>; }

  /** @override */
  created() {
>created : () => void

  },

  /** @private */
  onClose_() {
>onClose_ : () => void

  },

  /** @readonly */
  get value() {
>value : number

    return 1;
>1 : 1

  },

  /** @protected */
  set value(v) {
>value : number
>v : number

  },

  /** @public */
  async load() {
>load : () => Promise<void>

  },
};

